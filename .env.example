# ── LLM providers — at least one required ─────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# ── Literature search ──────────────────────────────────────────
NCBI_EMAIL=your@email.com
SEMANTIC_SCHOLAR_API_KEY=        # optional; raises rate limits

# ── Workspace ─────────────────────────────────────────────────
DEFAULT_USER=default

# ── Infrastructure (set automatically by docker-compose.yml) ──
# These are overridden per-service in compose; only set here if
# running the backend outside of Docker.
QDRANT_URL=http://localhost:6333
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=eln-kb
S3_ACCESS_KEY_ID=coscientist
S3_SECRET_ACCESS_KEY=coscientist
S3_REGION=us-east-1
DATABASE_URL=postgresql://coscientist:coscientist@localhost:5432/coscientist

# ── OpenTelemetry (optional) ───────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER=otlp
OTEL_ENDPOINT=http://localhost:4317
