# Copy to .env and fill in your values

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (Phase 6)
OPENAI_API_KEY=sk-...

# Google Gemini (Phase 6)
GOOGLE_API_KEY=...

# Literature (Phase 4)
NCBI_EMAIL=your@email.com
SEMANTIC_SCHOLAR_API_KEY=        # optional; raises S2 rate limit

# Workspace
DEFAULT_USER=default

# Storage backend (object store for RAG source files)
# "local" stores originals in workspaces/<user>/kb/<collection>/
# "s3"    stores originals in MinIO or AWS S3
STORAGE_BACKEND=local          # "local" | "s3"
S3_BUCKET=eln-kb
S3_ENDPOINT_URL=http://localhost:9000   # MinIO local; leave empty for AWS S3
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
# MinIO local (one-liner):
#   docker run -d -p 9000:9000 -p 9001:9001 \
#     -e MINIO_ROOT_USER=minioadmin -e MINIO_ROOT_PASSWORD=minioadmin \
#     minio/minio server /data --console-address ":9001"
# Console: http://localhost:9001

# OpenTelemetry — self-hosted traces (optional)
# To run Jaeger locally:
#   docker run -d -p 16686:16686 -p 4317:4317 jaegertracing/all-in-one
#   Then open http://localhost:16686 → Service: eln-plus-plus
OTEL_ENABLED=false
OTEL_EXPORTER=otlp                 # otlp | console
OTEL_ENDPOINT=http://localhost:4317
